{
  "title": "Spectra — ISM Health",
  "uid": "spectra-ism-health",
  "tags": ["spectra", "rf", "iot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-20m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "sensor",
        "type": "query",
        "datasource": "VictoriaMetrics",
        "query": "label_values(rf_sweep_noise_floor_db, sensor_id)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "jetson-desktop", "value": "jetson-desktop" }
      }
    ]
  },
  "panels": [
    {
      "title": "Active mode",
      "type": "stat",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "spectra_status_center_mhz{sensor_id=~\"$sensor\"}", "instant": true, "legendFormat": "" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value", "colorMode": "background", "graphMode": "none", "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "98": { "text": "📻 FM 88-108", "index": 0, "color": "blue" },
              "866.5": { "text": "📡 868 ISM", "index": 1, "color": "blue" },
              "2441.5": { "text": "📶 2.4 GHz WiFi/BT", "index": 2, "color": "purple" },
              "433.92": { "text": "🌡️ Weather 433", "index": 3, "color": "green" },
              "868.3": { "text": "🌡️ Weather 868", "index": 4, "color": "orange" }
            }}
          ],
          "noValue": "idle",
          "color": { "mode": "fixed", "fixedColor": "text" }
        }
      }
    },
    {
      "title": "HackRF mode — click to retune the radio",
      "type": "text",
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<iframe name=\"ctl\" style=\"display:none\"></iframe><div style=\"display:flex;flex-wrap:wrap;gap:10px;align-items:center;height:100%;padding:6px 4px;font-family:sans-serif\"><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=sweep868\" target=\"ctl\" style=\"background:#1f60c4;color:#fff;padding:9px 14px;border-radius:6px;text-decoration:none;font-weight:600\">📡 Sweep 868</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=sweepfm\" target=\"ctl\" style=\"background:#5a3fc0;color:#fff;padding:9px 14px;border-radius:6px;text-decoration:none;font-weight:600\">📻 Sweep FM</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=sweep24\" target=\"ctl\" style=\"background:#7a3f9c;color:#fff;padding:9px 14px;border-radius:6px;text-decoration:none;font-weight:600\">📶 Sweep 2.4 GHz</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=weather433\" target=\"ctl\" style=\"background:#37872d;color:#fff;padding:9px 14px;border-radius:6px;text-decoration:none;font-weight:600\">🌡️ Weather 433</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=weather868\" target=\"ctl\" style=\"background:#8a6d0b;color:#fff;padding:9px 14px;border-radius:6px;text-decoration:none;font-weight:600\">🌡️ Weather 868</a></div>"
      }
    },
    {
      "title": "Noise floor (dB)",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "rf_sweep_noise_floor_db{sensor_id=~\"$sensor\"}", "legendFormat": "{{sensor_id}}" }]
    },
    {
      "title": "Band occupancy ratio",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "rf_sweep_occupancy_ratio{sensor_id=~\"$sensor\"}", "legendFormat": "{{sensor_id}}" }]
    },
    {
      "title": "Interference flag",
      "type": "state-timeline",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "targets": [{ "expr": "rf_sweep_interference{sensor_id=~\"$sensor\"}", "legendFormat": "{{sensor_id}}" }]
    },
    {
      "title": "Peak power (dB)",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "targets": [{ "expr": "rf_sweep_peak_db{sensor_id=~\"$sensor\"}", "legendFormat": "{{sensor_id}}" }]
    },
    {
      "title": "Waterfall — power per frequency bin (dB)  [select ONE sensor]",
      "type": "heatmap",
      "datasource": "VictoriaMetrics",
      "description": "Spectrogram: frequency (Y) over time (X), colour = power. Pick a single sensor. Y axis adapts to the band you are sweeping.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 26 },
      "targets": [
        { "expr": "rf_spectrum_power_db{sensor_id=~\"$sensor\"}", "legendFormat": "{{freq_mhz}}", "format": "time_series", "range": true }
      ],
      "transformations": [
        { "id": "prepareTimeSeries", "options": { "format": "timeseries-wide" } }
      ],
      "options": {
        "calculate": false,
        "cellGap": 0,
        "rowsFrame": { "layout": "auto" },
        "filterValues": { "le": -1000000000 },
        "color": { "mode": "scheme", "scheme": "Turbo", "steps": 64, "min": -95, "max": -35, "reverse": false },
        "yAxis": { "axisPlacement": "left", "unit": "short", "decimals": 1 },
        "tooltip": { "show": true, "yHistogram": false },
        "legend": { "show": false }
      }
    },
    {
      "title": "📻 FM Radio — live audio (1: pick a station, 2: press ▶ Play)",
      "type": "text",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 38 },
      "options": {
        "mode": "html",
        "content": "<iframe name=\"ctl\" style=\"display:none\"></iframe><div style=\"font-family:sans-serif;padding:8px 4px\"><div style=\"color:#9aa;margin-bottom:8px\">1) clique une station &nbsp;&rarr;&nbsp; 2) appuie sur &#9654; dans le lecteur (re-appuie si tu changes de station)</div><div style=\"display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px\"><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=listenfm:100.2\" target=\"ctl\" style=\"background:#37872d;color:#fff;padding:8px 14px;border-radius:6px;text-decoration:none;font-weight:600\">🎵 Skyrock 100.2</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=listenfm:96.9\" target=\"ctl\" style=\"background:#c0392b;color:#fff;padding:8px 14px;border-radius:6px;text-decoration:none;font-weight:600\">❤️ Chérie 96.9</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=listenfm:106.1\" target=\"ctl\" style=\"background:#37872d;color:#fff;padding:8px 14px;border-radius:6px;text-decoration:none;font-weight:600\">NRJ 106.1</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=listenfm:91.8\" target=\"ctl\" style=\"background:#37872d;color:#fff;padding:8px 14px;border-radius:6px;text-decoration:none;font-weight:600\">Fun 91.8</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=listenfm:89.1\" target=\"ctl\" style=\"background:#37872d;color:#fff;padding:8px 14px;border-radius:6px;text-decoration:none;font-weight:600\">France Inter 89.1</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=listenfm:105.1\" target=\"ctl\" style=\"background:#37872d;color:#fff;padding:8px 14px;border-radius:6px;text-decoration:none;font-weight:600\">Info 105.1</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=sweep868\" target=\"ctl\" style=\"background:#777;color:#fff;padding:8px 14px;border-radius:6px;text-decoration:none;font-weight:600\">&#9209; Stop</a></div><audio controls preload=\"none\" style=\"width:100%;max-width:520px\" src=\"http://192.168.1.55:30900/fm.mp3\"></audio></div>"
      }
    },
    {
      "title": "🛰️ Detected objects — decoded RF devices (weather sensors, etc.)",
      "type": "logs",
      "datasource": "Loki",
      "description": "Live stream of decoded objects from the rtl_433/weather modes. Empty until a 433/868 device transmits nearby.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 45 },
      "targets": [{ "expr": "{job=\"spectra-devices\"}", "refId": "A" }],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
