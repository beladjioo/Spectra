{
  "title": "Spectra — ISM Health",
  "uid": "spectra-ism-health",
  "tags": ["spectra", "rf", "iot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "sensor",
        "type": "query",
        "datasource": "VictoriaMetrics",
        "query": "label_values(rf_sweep_noise_floor_db, sensor_id)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "title": "Noise floor (dB)",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rf_sweep_noise_floor_db{sensor_id=~\"$sensor\"}",
          "legendFormat": "{{sensor_id}}"
        }
      ]
    },
    {
      "title": "Band occupancy ratio",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rf_sweep_occupancy_ratio{sensor_id=~\"$sensor\"}",
          "legendFormat": "{{sensor_id}}"
        }
      ]
    },
    {
      "title": "Interference flag",
      "type": "state-timeline",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rf_sweep_interference{sensor_id=~\"$sensor\"}",
          "legendFormat": "{{sensor_id}}"
        }
      ]
    },
    {
      "title": "Peak power (dB)",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "rf_sweep_peak_db{sensor_id=~\"$sensor\"}",
          "legendFormat": "{{sensor_id}}"
        }
      ]
    },
    {
      "title": "Waterfall — power per frequency bin (dB)  [select ONE sensor]",
      "type": "heatmap",
      "datasource": "VictoriaMetrics",
      "description": "Spectrogram: frequency (Y) over time (X), colour = power. Pick a single sensor in the dropdown for a clean view.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "rf_spectrum_power_db{sensor_id=~\"$sensor\"} + 120",
          "legendFormat": "{{freq_mhz}}",
          "format": "time_series",
          "range": true
        }
      ],
      "transformations": [
        { "id": "prepareTimeSeries", "options": { "format": "timeseries-wide" } }
      ],
      "options": {
        "calculate": false,
        "cellGap": 0,
        "rowsFrame": { "layout": "auto" },
        "filterValues": { "le": -1000000000 },
        "color": {
          "mode": "scheme",
          "scheme": "Turbo",
          "steps": 64,
          "min": 20,
          "max": 85,
          "reverse": false
        },
        "yAxis": {
          "axisPlacement": "left",
          "unit": "short",
          "decimals": 1
        },
        "tooltip": { "show": true, "yHistogram": false },
        "legend": { "show": false }
      }
    }
  ]
}
