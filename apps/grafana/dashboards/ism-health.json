{
  "title": "Spectra — ISM Health",
  "uid": "spectra-ism-health",
  "tags": ["spectra", "rf", "iot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-20m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "sensor",
        "type": "query",
        "datasource": "VictoriaMetrics",
        "query": "label_values(rf_sweep_noise_floor_db, sensor_id)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "jetson-desktop", "value": "jetson-desktop" }
      }
    ]
  },
  "panels": [
    {
      "title": "HackRF mode — click to retune the radio",
      "type": "text",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<iframe name=\"ctl\" style=\"display:none\"></iframe><div style=\"display:flex;gap:14px;align-items:center;height:100%;padding:6px 4px;font-family:sans-serif\"><span style=\"color:#9aa;margin-right:4px\">HackRF&nbsp;:</span><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=sweep\" target=\"ctl\" style=\"background:#1f60c4;color:#fff;padding:10px 18px;border-radius:6px;text-decoration:none;font-weight:600\">📡 Sweep 868</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=weather433\" target=\"ctl\" style=\"background:#37872d;color:#fff;padding:10px 18px;border-radius:6px;text-decoration:none;font-weight:600\">🌡️ Weather 433</a><a href=\"http://192.168.1.55:30890/?sensor=jetson-desktop&mode=weather868\" target=\"ctl\" style=\"background:#8a6d0b;color:#fff;padding:10px 18px;border-radius:6px;text-decoration:none;font-weight:600\">🌡️ Weather 868</a></div>"
      }
    },
    {
      "title": "Noise floor (dB)",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "rf_sweep_noise_floor_db{sensor_id=~\"$sensor\"}", "legendFormat": "{{sensor_id}}" }]
    },
    {
      "title": "Band occupancy ratio",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "rf_sweep_occupancy_ratio{sensor_id=~\"$sensor\"}", "legendFormat": "{{sensor_id}}" }]
    },
    {
      "title": "Interference flag",
      "type": "state-timeline",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "targets": [{ "expr": "rf_sweep_interference{sensor_id=~\"$sensor\"}", "legendFormat": "{{sensor_id}}" }]
    },
    {
      "title": "Peak power (dB)",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "targets": [{ "expr": "rf_sweep_peak_db{sensor_id=~\"$sensor\"}", "legendFormat": "{{sensor_id}}" }]
    },
    {
      "title": "Waterfall — power per frequency bin (dB)  [select ONE sensor]",
      "type": "heatmap",
      "datasource": "VictoriaMetrics",
      "description": "Spectrogram: frequency (Y) over time (X), colour = power. Pick a single sensor.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 26 },
      "targets": [
        { "expr": "rf_spectrum_power_db{sensor_id=~\"$sensor\"}", "legendFormat": "{{freq_mhz}}", "format": "time_series", "range": true }
      ],
      "transformations": [
        { "id": "prepareTimeSeries", "options": { "format": "timeseries-wide" } }
      ],
      "options": {
        "calculate": false,
        "cellGap": 0,
        "rowsFrame": { "layout": "auto" },
        "filterValues": { "le": -1000000000 },
        "color": { "mode": "scheme", "scheme": "Turbo", "steps": 64, "min": -95, "max": -35, "reverse": false },
        "yAxis": { "axisPlacement": "left", "unit": "short", "decimals": 1 },
        "tooltip": { "show": true, "yHistogram": false },
        "legend": { "show": false }
      }
    }
  ]
}
