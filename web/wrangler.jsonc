// Cloudflare Workers config: serve the built app as a static-assets Worker.
// Used by Cloudflare's Git integration (build: `npm run build`, deploy:
// `npx wrangler deploy`, root directory: `web`).
{
  "name": "rf-academy",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
