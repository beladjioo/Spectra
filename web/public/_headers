# Hashed build assets are immutable; fonts and the OG image are long-lived;
# every (pre-rendered) HTML page must revalidate so a new deploy is picked up
# immediately. More specific paths win over /*.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
/fonts/*
  Cache-Control: public, max-age=2592000
/og.png
  Cache-Control: public, max-age=604800
/favicon.svg
  Cache-Control: public, max-age=604800
/*
  Cache-Control: no-cache
